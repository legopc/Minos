loglevel = "info"

sdo-id = 0
domain = 0
priority1 = 255  # Always lose BMCA election — external clock (e.g. Biamp) must be master
virtual-system-clock = true
virtual-system-clock-base = "monotonic_raw"
usrvclock-export = true

[[port]]
interface = "enp1s0"   # ← set to your wired NIC (run: ip link show)
network-mode = "ipv4"

# "auto" uses hardware PTP if the NIC supports it (e.g. Intel I219-LM),
# falls back to software timestamping (e.g. Realtek RTL8111) automatically.
hardware-clock = "auto"

protocol-version = "PTPv1"
