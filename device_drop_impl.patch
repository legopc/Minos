+/// Graceful shutdown guard: ensures DeviceServer resources are cleaned up
+/// when DanteDevice is dropped, preventing mDNS broadcaster and TX/RX task leaks.
+///
+/// **Rationale (from inferno-shutdown analysis):**
+/// - Without explicit shutdown, DeviceServer drops its internal tasks abruptly
+/// - Active Dante subscriptions (held by remote devices like MXWANI8) stay alive
+/// - Result: silence on subscriber side, not a resource leak on our side
+/// - This Drop impl provides graceful degradation: best-effort cleanup on panic/exit
+///
+/// **Implementation:**
+/// - shutdown() is async, Drop is sync → use tokio::runtime::Handle
+/// - If no runtime available (unlikely), log warning and proceed with abrupt drop
+/// - Handle::block_on is safe here: we're not in an async context (Drop is sync)
+#[cfg(feature = "inferno")]
+impl Drop for DanteDevice {
+    fn drop(&mut self) {
+        // Extract the server from the Mutex (take ownership for shutdown)
+        let server = self.server.lock().unwrap().take();
+        
+        if let Some(server) = server {
+            tracing::info!(
+                device = %self.device_name,
+                "DanteDevice dropped — initiating graceful shutdown"
+            );
+            
+            // Attempt to get the current tokio runtime handle.
+            // This works if we're being dropped from within a tokio runtime context
+            // (which is the typical case in patchbox — main.rs runs tokio::main).
+            match tokio::runtime::Handle::try_current() {
+                Ok(handle) => {
+                    // Spawn a blocking task to run the async shutdown.
+                    // We can't use Handle::block_on directly in Drop because it might
+                    // deadlock if Drop is called from within an async context on the
+                    // same runtime. spawn_blocking ensures it runs on a dedicated thread.
+                    let device_name = self.device_name.clone();
+                    handle.spawn_blocking(move || {
+                        // Create a new single-threaded runtime for this shutdown.
+                        // We can't use block_on on the main runtime from a blocking task,
+                        // so we create a minimal runtime just for this operation.
+                        let rt = tokio::runtime::Runtime::new()
+                            .expect("Failed to create shutdown runtime");
+                        
+                        rt.block_on(async move {
+                            tracing::debug!(device = %device_name, "Calling DeviceServer::shutdown()");
+                            server.shutdown().await;
+                            tracing::info!(device = %device_name, "DeviceServer shutdown complete");
+                        });
+                    });
+                    
+                    // Note: We don't wait for the spawn_blocking task to complete.
+                    // This is intentional — if we're dropping during a panic or forced
+                    // shutdown, blocking here could hang the entire process.
+                    // The shutdown task will complete in the background, and the runtime
+                    // will clean it up on process exit.
+                }
+                Err(_) => {
+                    // No runtime available — this can happen if DanteDevice is dropped
+                    // after the main runtime has shut down, or in a test context.
+                    tracing::warn!(
+                        device = %self.device_name,
+                        "No tokio runtime available for graceful shutdown — DeviceServer will drop abruptly"
+                    );
+                    // server drops here — mDNS broadcaster + tasks will be killed
+                }
+            }
+        }
+    }
+}
+
 /// R-11: Set SCHED_FIFO priority on the calling thread (Linux only).
 /// Uses a thread-local flag so the syscall is made at most once per thread.
 /// Requires either `CAP_SYS_NICE` or a `/etc/security/limits.d/` rule
